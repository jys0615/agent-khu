# ----------------------------
# ENV files (절대 커밋 금지)
# ----------------------------
# ENV files
.env
*.env
**/.env
backend/.env
frontend/.env
mcp-servers/**/.env

# example 파일은 허용(실값 금지)
!backend/.env.example
!frontend/.env.example
!mcp-servers/**/.env.example

# ----------------------------
