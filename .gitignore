# ----------------------------
__pycache__/
*.py[cod]
*.sqlite3
*.db
.venv/
venv/
ENV/
*.log
backend/.pytest_cache/
backend/.mypy_cache/
backend/.coverage

# ----------------------------
# Node / React frontend
# ----------------------------
node_modules/
dist/
build/
.cache/
*.log
frontend/.vite/
frontend/.eslintcache

